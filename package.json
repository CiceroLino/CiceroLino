{
  "name": "cicerolino",
  "author": {
    "name": "CiceroLino",
    "github": "https://github.com/CiceroLino"
  },
  "git": "https://github.com/CiceroLino/cicerolino.git",
  "description": "Personal landing page portfolio",
  "version": "2.0.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
